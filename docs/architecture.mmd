flowchart TD
    subgraph USER["User Layer"]
      user(User)
    end

    subgraph APP["Application Layer"]
      fe[Streamlit Frontend]
      api[FastAPI Backend]
    end

    subgraph RAG["RAG Core Pipeline"]
      direction TB
      qp[Query Processing & Guardrails]
      emb[Query Embedding]
      hr[Hybrid Retrieval]
      rr[Reranking]
      llm[LLM Generation & Citation Validation]
      qp --> emb --> hr --> rr --> llm
    end

    subgraph DATA["Data Layer — Indexing & Storage"]
      direction TB
      load[Document Loaders]
      chunk[Chunking]
      demb[Embeddings]
      faiss[FAISS Index]
      bm25idx[BM25 Index]
      load --> chunk
      chunk --> demb --> faiss
      chunk --> bm25idx
    end

    subgraph SUPPORT["Supporting Systems"]
      auth[JWT + OAuth + RBAC]
      guards[Domain & Safety Guardrails]
      metrics[Metrics & Health Checks]
      docker[Docker · Cloud Run]
    end

    user --> fe
    fe --> api
    api --> qp
    llm --> api

    faiss -.->|"vector index"| hr
    bm25idx -.->|"lexical index"| hr

    auth --> api
    guards --> qp
    api --> metrics
    docker --> api

    classDef main fill:#e1f5fe,stroke:#01579b
    class qp,emb,hr,rr,llm main